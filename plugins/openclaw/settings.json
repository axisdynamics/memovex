{
  "_readme": "Run `python scripts/setup_plugin.py --agent openclaw --output /your/project/.claude/settings.json` to generate this with correct absolute paths.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /YOUR_MEMOVEX_PATH/plugins/openclaw/hooks/memory_inject.py",
            "timeout": 8,
            "statusMessage": "Consultando memoria [openclaw]..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /YOUR_MEMOVEX_PATH/plugins/openclaw/hooks/memory_store.py",
            "timeout": 15,
            "statusMessage": "Guardando en memoria [openclaw]..."
          }
        ]
      }
    ]
  }
}
